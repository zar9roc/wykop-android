<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    >

    <ImageView
        android:id="@+id/imgPreview"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:clickable="false"
        android:focusable="false"
        android:duplicateParentState="true"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible"
        tools:background="#ff00ff"
        />

    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="4dp"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:textAppearance="@style/TextAppearance.MaterialScale.Body1"
        android:textStyle="bold"
        android:clickable="false"
        android:focusable="false"
        android:duplicateParentState="true"
        app:layout_constraintTop_toBottomOf="@id/imgPreview"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        tools:text="Tytu\u0142 znaleziska"
        />

    <TextView
        android:id="@+id/txtDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingBottom="6dp"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:textAppearance="@style/TextAppearance.MaterialScale.Body2"
        android:clickable="false"
        android:focusable="false"
        android:duplicateParentState="true"
        app:layout_constraintTop_toBottomOf="@+id/txtTitle"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        tools:text="Opis znaleziska"
        />

    <View
        android:id="@+id/separator1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?colorDivider"
        app:layout_constraintTop_toBottomOf="@id/txtDescription"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />

    <HorizontalScrollView
        android:id="@+id/detailsScrollView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/separator1"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        >

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            >

            <com.github.wykopmobilny.ui.components.AvatarView
                android:id="@+id/imgAvatar"
                android:layout_width="36dp"
                android:layout_height="wrap_content"
                android:paddingLeft="12dp"
                />

            <TextView
                android:id="@+id/txtUser"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:textAppearance="@style/TextAppearance.MaterialScale.Caption"
                tools:text="Powodzenia"
                />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="?colorDivider"
                />

            <TextView
                android:id="@+id/txtTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:textAppearance="@style/TextAppearance.MaterialScale.Caption"
                tools:text="2 godz. temu"
                />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="?colorDivider"
                />

            <TextView
                android:id="@+id/txtDomain"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:textAppearance="@style/TextAppearance.MaterialScale.Caption"
                tools:text="wykop.pl"
                />

            <View
                android:id="@+id/tagsSeparator"
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="?colorDivider"
                />

            <LinearLayout
                android:id="@+id/tagsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:gravity="center_vertical"
                />

        </LinearLayout>

    </HorizontalScrollView>

    <View
        android:id="@+id/separator2"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="?colorDivider"
        app:layout_constraintTop_toBottomOf="@id/detailsScrollView"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        />

    <TextView
        android:id="@+id/shareButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?selectableItemBackgroundBorderless"
        android:gravity="center"
        android:padding="8dp"
        app:drawableStartCompat="@drawable/ic_share"
        app:drawableTint="?colorControlNormal"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/separator2"
        />

    <TextView
        android:id="@+id/favoriteButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?selectableItemBackgroundBorderless"
        android:gravity="center"
        android:padding="8dp"
        app:drawableStartCompat="@drawable/ic_favorite_outlined"
        app:layout_constraintLeft_toRightOf="@id/shareButton"
        app:layout_constraintTop_toBottomOf="@id/separator2"
        />

    <TextView
        android:id="@+id/relatedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?selectableItemBackground"
        android:drawablePadding="4dp"
        android:gravity="center"
        android:paddingHorizontal="6dp"
        android:paddingVertical="4dp"
        android:textAppearance="@style/TextAppearance.MaterialScale.Body2"
        android:visibility="gone"
        app:drawableStartCompat="@drawable/ic_link"
        app:layout_constraintRight_toLeftOf="@+id/commentButton"
        app:layout_constraintTop_toBottomOf="@id/separator2"
        tools:text="3"
        tools:visibility="visible"
        />

    <TextView
        android:id="@+id/commentButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?selectableItemBackground"
        android:drawablePadding="4dp"
        android:gravity="center"
        android:paddingHorizontal="6dp"
        android:paddingVertical="4dp"
        android:textAppearance="@style/TextAppearance.MaterialScale.Body2"
        app:drawableStartCompat="@drawable/ic_comment"
        app:layout_constraintRight_toLeftOf="@+id/voteButton"
        app:layout_constraintTop_toBottomOf="@id/separator2"
        tools:text="12"
        />

    <TextView
        android:id="@+id/voteButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?selectableItemBackground"
        android:drawablePadding="2dp"
        android:gravity="center"
        android:paddingHorizontal="6dp"
        android:paddingVertical="4dp"
        android:textAppearance="@style/TextAppearance.MaterialScale.Body2"
        app:drawableStartCompat="@drawable/ic_logo"
        app:layout_constraintEnd_toStartOf="@id/moreButton"
        app:layout_constraintTop_toBottomOf="@id/separator2"
        tools:text="234"
        />

    <TextView
        android:id="@+id/moreButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="?selectableItemBackgroundBorderless"
        android:gravity="center"
        android:padding="8dp"
        app:drawableStartCompat="@drawable/ic_more"
        app:drawableTint="?colorControlNormal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/separator2"
        />

    <View
        android:id="@+id/hotIcon"
        android:layout_width="11dp"
        android:layout_height="11dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="2dp"
        android:visibility="gone"
        app:layout_constraintLeft_toLeftOf="@id/voteButton"
        app:layout_constraintTop_toTopOf="@id/voteButton"
        tools:visibility="visible"
        />

    <View
        android:id="@+id/separator3"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="?colorDivider"
        app:layout_constraintTop_toBottomOf="@id/favoriteButton"
        />

    <View
        android:id="@+id/hotBadgeStrip"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:background="#ff00ff"
        tools:visibility="visible"
        />

</androidx.constraintlayout.widget.ConstraintLayout>
